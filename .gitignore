# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local secrets. The glob matters: rotating the token invites a `cp .env
# .env.bak` first, and a bare `.env` rule leaves that backup tracked.
.env
.env.*
!.env.example

# Live memory files — personal data; ship memory.example/ instead.
# On first run, copy memory.example/ to memory/.
/memory/
