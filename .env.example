# Bearer token clients must send as `Authorization: Bearer <token>`.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MEMORY_TOKEN=

# Where the markdown files live (relative to project root or absolute).
MEMORY_DIR=memory

# Bind address and port.
HOST=127.0.0.1
PORT=3333

# Set to true when the server is behind a reverse proxy that forwards the
# public hostname (e.g. Tailscale Funnel). Disables FastMCP's DNS-rebinding
# Host-header check so the proxied requests aren't rejected. Bearer auth
# still gates access; this only relaxes the Host check.
TRUST_PROXY=false

# Memories marked `scope: private` in their frontmatter are hidden from every
# tool. Set this to true to serve them anyway — only safe on a server that is
# not publicly reachable.
SERVE_PRIVATE=false
